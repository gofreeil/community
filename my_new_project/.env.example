# ================================================================
# קובץ זה הוא תבנית — צור .env ומלא את הערכים האמיתיים
# ================================================================

# Resend API Key — נדרש לשליחת מיילי אישור הזמנה
# הירשם בחינם על https://resend.com  →  API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# כתובת שממנה יישלחו המיילים
# ב-Resend חינמי ניתן להשתמש ב: onboarding@resend.dev (לטסטים)
# לייצור: אמת את הדומיין שלך ב-Resend ואז השתמש ב-ads@shchuna.co.il
FROM_EMAIL=onboarding@resend.dev

# ================================================================
# Auth.js — Google + Facebook OAuth
# ================================================================

# AUTH_SECRET — מחרוזת אקראית לחתימת JWT (חובה!)
# ייצר עם: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com
# APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Authorized redirect URIs: http://localhost:5173/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Facebook OAuth — https://developers.facebook.com
# My Apps → Add Product → Facebook Login
# Valid OAuth Redirect URIs: http://localhost:5173/auth/callback/facebook
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
