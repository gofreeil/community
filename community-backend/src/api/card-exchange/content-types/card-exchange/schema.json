{
  "kind": "collectionType",
  "collectionName": "card_exchanges",
  "info": {
    "singularName": "card-exchange",
    "pluralName": "card-exchanges",
    "displayName": "Card Exchange"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "user1": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "card_exchanges_initiated"
    },
    "user2": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "card_exchanges_received"
    },
    "message": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "accepted", "rejected", "completed"],
      "default": "pending"
    }
  }
}
