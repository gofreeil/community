{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Post",
    "description": "פוסטים/חדשות קהילתיים - מוצגים ב-NewsTicker ומופצים דרך /api/community-news"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "category": {
      "type": "string"
    },
    "sourceUrl": {
      "type": "string"
    },
    "archived": {
      "type": "boolean",
      "default": false
    },
    "imageUrl": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
