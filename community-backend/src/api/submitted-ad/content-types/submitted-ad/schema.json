    },
    "subtitle": {
      "type": "text"
    },
    "hover_text": {
      "type": "text"
    },
    "cta": {
      "type": "string"
    },
    "gradient": {
      "type": "string"
    },
    "logo": {
      "type": "text"
    },
    "main_image": {
      "type": "text"
    },
    "landing": {
      "type": "json"
    },
    "submitted_by_id": {
      "type": "string"
    },
    "submitted_by_email": {
      "type": "string"
    },
    "submitted_by_name": {
      "type": "string"
    },
    "submitted_at": {
      "type": "datetime"
    },
    "decided_at": {
      "type": "datetime"
    },
    "decided_by": {
      "type": "string"
    },
    "rejection_reason": {
      "type": "text"
